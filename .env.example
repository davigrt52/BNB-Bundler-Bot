# Wallet that signs bundle transactions (hex private key, with or without 0x)
PRIVATE_KEY=


# BSC JSON-RPC URL (defaults in code use public seeds if unset; use your own for reliability)
RPC_URL=https://bsc-dataseed1.binance.org/

# bloXroute API base URL (default: https://api.blxrbdn.com)
BLOXROUTE_ENDPOINT=https://api.blxrbdn.com

# bloXroute API authorization header (from your bloXroute dashboard)
AUTHORIZATION_HEADER=

# --- Token & bundle tuning (optional) ---
TOKEN_NAME=MyToken
TOKEN_SYMBOL=MTK
TOKEN_SUPPLY=1000000
GAS_PRICE_MULTIPLIER=1.2
FUTURE_BLOCK_OFFSET=5
FEE_TIER=3000
INITIAL_PRICE=1

# --- Hardhat (deploy, verify, fork tests) ---
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
BSC_FORK_URL=https://bsc-dataseed1.binance.org/
BSCSCAN_API_KEY=
FORK_BLOCK_NUMBER=

# --- Optional tooling ---
# REPORT_GAS=true
# COINMARKETCAP_API_KEY=
